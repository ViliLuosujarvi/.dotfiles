{
    "layer": "top",
    "position": "top",
    "height": 12,
    "margin-bottom": 2,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 8,
    "output": "eDP-1",
    "modules-left": ["clock", "hyprland/workspaces"],
    //"modules-center": ["clock", "custom/weather"],
    //"modules-right": ["network", "group/system-info", "disk", "memory", "custom/nvidia", "group/cpu_info", "battery", "tray"],
      "modules-right": ["network", "custom/nvidia", "group/cpu_info", "memory" ,"disk", "group/system-info", "pulseaudio#microphone", "battery", "tray", "keyboard-state"],



	//cute cats can be found here:
	//https://emojidb.org/cat-ascii-emojis
    "hyprland/workspaces": {
        "format": "{icon} {id}",
        "on-click": "activate",
        "all-outputs": true,
        "sort-by-number": true,
        "format-icons": {
	"1": "  /\\_/\\  \n ~(вЙІвЦљвЙ¶)~  \n   >гБ•гБ•  ",
        "2": "  /\\_/\\  \n (вАҐ . вАҐ?)  \n  >гБ•гБ•   ",
        "3": "  /\\_/\\  \n   (аЄЕвАҐ . вАҐаЄЕ) вЩ°  \n  > гБ•гБ• ",
        "4": "  /\\_/\\  \n ( - ѕЙ - ) zzZ  \n  >  вКГвКГ ",
        "5": "  /\\_/\\  \n  (O_O;)  \n  >гБ•гБ•  ",
        "6": "  /\\_/\\  \n ( вАҐ ѕЙ вАҐ )  \n / гБ• вЩ°  ",
        "7": "  /\\_/\\  \n  (¬ђвАњ¬ђ)  \n  >гБ•гБ•  ",
        "8": "  /\\_/\\  \n (¬∞w¬∞)  \n  >гБ•гБ•  ",
        "9": "  /\\_/\\  \n  (вЙЦ_вЙЦ)  \n  >гБ•гБ•  ",
        "10": " /\\_/\\  \n (вЬњ^вАњ^)  \n  >гБ•гБ• ",
        "urgent": "  /\\_/\\  \n (вКЩпєПвКЩ;)  \n  >гБ•гБ•  ",
	"active": "  вИІ,,,вИІ         вЩ°вЩ°\n(  ћ≥вАҐ ¬Ј вАҐ ћ≥)   you\n/    гБ• вЩ° I love   ",
	"default": "  /\\_/\\  \n (¬∞w¬∞)  \n  >гБ•гБ•"
        }
    },

// ----------------------

	// old order of cats :3

	//"1": "  /\\_/\\  \n (вМРвЦ†_вЦ†)  \n  >гБ•гБ•  1",
        //"2": "  /\\_/\\  \n (вАҐ . вАҐ?)  \n  >гБ•гБ•   2",
        //"3": "  /\\_/\\  \n ( - ѕЙ - ) zzZ  \n  >  вКГвКГ       3",
        //"4": "  /\\_/\\  \n ~(вЙІвЦљвЙ¶)~  \n  >гБ•гБ•  4",
        //"5": "  /\\_/\\  \n (вЬњ^вАњ^)  \n  >гБ•гБ•  5",
        //"6": "  /\\_/\\  \n (O_O;)  \n  >гБ•гБ•  6",
        //"7": "  /\\_/\\  \n ( вАҐ ѕЙ вАҐ )  \n / гБ• вЩ°   7",
        //"8": "  /\\_/\\  \n (аЄЕвАҐ . вАҐаЄЕ)вЩ°  \n  > гБ•гБ•  8",
        //"9": "  /\\_/\\  \n (вЙЦ_вЙЦ)  \n  >гБ•гБ•  9",
        //"10": "  /\\_/\\  \n (¬ђвАњ¬ђ)  \n  >гБ•гБ•  10",
        //"urgent": "  /\\_/\\  \n (вКЩпєПвКЩ;)  \n  >гБ•гБ•  ",
	//"active": "  вИІ,,,вИІ\n(  ћ≥вАҐ ¬Ј вАҐ ћ≥)\n/    гБ•вЩ° I love you",
	//"default": "  /\\_/\\  \n (¬∞w¬∞)  \n  >гБ•гБ•  "

// -----------------------

   "keyboard-state": {
	"numlock": true,
	"capslock": true,
	"format": "{name}  {icon}",
	"format-icons": {
		"locked": "пА£",
		"unlocked": "пВЬ"
	}
    },

    "disk": {
        "interval": 30,
        "format": "у∞ЛК {percentage_used}%",
        "path": "/",
        "tooltip": true,
        "unit": "GB",
        "tooltip-format":  "Available {free} of {total}"
    },

    //"custom/weather": {
    //    "format": "{}¬∞",
    //    "tooltip": true,
    //    "interval": 30,
    //    "exec": "curl -s 'https://wttr.in/?format=%t'",
    //    "exec-if": "ping wttr.in -c1"
    //},

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },

    "clock": {
	"interval": 1,
       "format": "{:%H:%M:%OS  пЭУ пЫХ  пЭУ  %d/%m}",
        "format-alt": "{:%Y-%m-%d}",
        "tooltip-format": "<big>{:%A, %B %d, %Y}</big>\n<small>{calendar}</small>",
        "calendar": {
            "mode": "month",
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#eee8d5'>{}</span>",
                "weeks": "<span color='#93a1a1'>{}</span>",
                "weekdays": "<span color='#268bd2'>{}</span>",
                "today": "<span color='#d33682'><b>{}</b></span>"
            },
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "cpu": {
        "format": "CPU: у∞ШЪ {usage}%",
        "tooltip": true,
        "interval": 1
    },

    "memory": {
	// у∞НЫ
        "format": "пФЄ {percentage}% пЫ® {swapPercentage}%",
        "tooltip-format": "{used:0.1f}GB / {total:0.1f}GB  {swapUsed}GB / {swapTotal}GB",
        "interval": 1
    },

    "temperature": {
	"thermal-zone": 2,
	//"hwmon-path": "/sys/class/hwmon/hwmon0/temp1_input",
	"interval": 10,
        "critical-threshold": 90,
        "format": "{icon} {temperatureC}¬∞C",
        "format-icons": ["у±ГГ", "у∞ФП", "у±ГВ"]
    },

    "group/cpu_info": {
	"orientation": "horizontal",
	"modules": [
		"cpu",
		"temperature"
	]

    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 35,
            "critical": 20
        },
        "format": "{icon} {capacity}%",
        "format-charging": "у∞ВД {capacity}%",
        "format-plugged": "у∞Ъ• {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["у∞ВО", "у∞БЇ", "у∞Бї", "у∞БЉ", "у∞Бљ", "у∞БЊ", "у∞Бњ", "у∞ВА", "у∞ВБ", "у∞ВВ", "у∞Бє"]
    },

    "network": {
        //"format-wifi": "у∞Ц© {essid}",
        //"format-ethernet": "у∞ИА {ipaddr}",
        //"tooltip-format": "{ifname}: {ipaddr}/{cidr}\nу∞Ц© {essid} ({signalStrength}%)",
        //"format-linked": "у±ШЦ {ifname}",
        //"format-disconnected": "у∞ѓ° Offline",
        //"format-alt": "{bandwidthUpBits} у∞БЭ {bandwidthDownBits}"

	"format-wifi" : "у∞Ц©  пБҐ {bandwidthUpBits}  пБ£ {bandwidthDownBits} ({signalStrength}%)    ",            
        "format-ethernet": "у∞ИА  пБҐ {bandwidthUpBits:8}  пБ£ {bandwidthDownBits:8}    ",
        "format-disconnected" : "у∞ѓ°  no network",
        "interval": 1,
        "tooltip": false
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "у∞ЭЯ ",
        "format-icons": {
            "headphone": "у∞ЛЛ",
            "hands-free": "у∞ЛО",
            "headset": "у∞ЛО",
            "phone": "у∞П≤",
            "portable": "у∞П≤",
            "car": "у∞ДЛ",
            "default": ["у∞Хњ", "у∞ЦА", "у∞ХЊ"]
         },
          "on-click": "pavucontrol",
          "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
      },

    "pulseaudio#microphone": {
	"format": "{format_source}",
	"format-source": "пД∞",
	"format-source-muted": "пД± ",
	//"on-click": "$HOME/.config/hypr/scripts/Volume.sh --toggle-mic",
	//"on-click-right": "pavucontrol -t 4",
	//"on-scroll-up": "$HOME/.config/hypr/scripts/Volume.sh --mic-inc",
	//"on-scroll-down": "$HOME/.config/hypr/scripts/Volume.sh --mic-dec",
	"tooltip-format": "{source_desc} | {source_volume}%",
	"scroll-step": 5,
    },


    "backlight": {
      "interval": 1,
      "device": "intel_backlight",
      "format": "{icon}{percent}%",
      "format-icons": [
	//"оПХ",
	//"оПЦ",
	//"оПЧ",
	//"оПШ",
	//"оПЩ",
	//"оПЪ",
	//"оПЫ",
	//"оПЬ",
	//"оПЭ",
	//"оПЮ",
	//"оПЯ",
	//"оП†",
	//"оП°",
	//"оПҐ",
	//"оП£"

	"оПХ ",
	"оПЧ ",
	"оПЪ ",
	"у∞ГЭ ",
	"у∞ГЮ ",
	"у∞ГЯ ",
	"у∞Г† "
      ],
      "on-scroll-down": "brightnessctl s 1%-",
      "on-scroll-up": "brightnessctl s +1%",
      "tooltip": true,
      "tooltip-format": "Brightness: {percent}% ",
      "smooth-scrolling-threshold": 1
  },      


    "group/system-info": {
	"orientation": "horizontal",
	"modules": [
		"pulseaudio",
		//"pulseaudio#microphone",
		"backlight"
	]
    },


    //"custom/nvidia": {
     //"exec": "nvidia-smi --query-gpu=pstate,utilization.gpu,temperature.gpu --format=csv,noheader,nounits | awk -F', ' '{printf \"GPU: \\uf0e7 %s  \\uf2db %s%%  \\uf2c9 %s¬∞C\", $1, $2, $3}'",
     //"interval": 5

    "custom/nvidia": {
     "exec": "nvidia-smi --query-gpu=pstate,utilization.memory,utilization.gpu,temperature.gpu --format=csv,noheader,nounits | awk -F', ' '{printf \"GPU: \\uf0e7 %s пФЄ %s%% \\uf2db %s%% \\uf2c9 %s¬∞C\", $1, $2, $3, $4}'",
     "interval": 1


	//"exec": "nvidia-smi --query-gpu=pstate,utilization.gpu,temperature.gpu --format=csv,noheader,nounits",
	//"format":"GPU: {}",
	//"return-type": "",
	//"interval": 2
	
    }

}
